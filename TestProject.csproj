<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <TargetFramework>net9.0</TargetFramework>
    <Configurations>Release</Configurations>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>
    <Optimize>true</Optimize>
    <OutputPath>Bin\</OutputPath>
    <IntermediateOutputPath>Bin\Objs\</IntermediateOutputPath>
    <DefineConstants></DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <ImplicitUsing>enable</ImplicitUsing>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <Reference Include="MochiSharp.Managed">
      <HintPath>Bin\MochiSharp.Managed.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Class\Base\ActionCard.cs" />
    <Compile Include="Class\Base\Card.cs" />
    <Compile Include="Class\Base\DebtContract.cs" />
    <Compile Include="Class\Base\EPolicyType.cs" />
    <Compile Include="Class\Base\ERarity.cs" />
    <Compile Include="Class\Base\JunkCard.cs" />
    <Compile Include="Class\Base\PassiveCard.cs" />
    <Compile Include="Class\Base\PolicyCard.cs" />
    <Compile Include="Scripts\GameManager.cs" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="IgniteScriptEngine">
      <HintPath>Bin\IgniteScriptEngine.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>